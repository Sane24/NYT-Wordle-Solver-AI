{
  "name": "wordle-solver-ai",
  "version": "1.0.0",
  "description": "Wordle Solver AI — genetic algorithm vs information theory, as a website and Discord bot",
  "type": "module",
  "scripts": {
    "precompute": "node scripts/precompute-openers.js",
    "evolve": "node scripts/evolve.js",
    "benchmark": "node scripts/benchmark.js",
    "serve": "python3 -m http.server 8917",
    "bot": "node --env-file-if-exists=bot/.env bot/index.js",
    "bot:deploy": "node --env-file-if-exists=bot/.env bot/deploy-commands.js"
  },
  "dependencies": {
    "discord.js": "^14.16.0",
    "dotenv": "^16.4.0"
  }
}
